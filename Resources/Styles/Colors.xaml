<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- PRIMARY BRAND -->
    <Color x:Key="Primary">#3B82F6</Color>
    <!-- Blue -->
    <Color x:Key="PrimaryDark">#1E40AF</Color>
    <Color x:Key="PrimaryLight">#DBEAFE</Color>

    <!-- BACKGROUNDS -->
    <Color x:Key="AppBackground">#EEF2F7</Color>
    <Color x:Key="CardBackground">#FFFFFF</Color>
    <Color x:Key="SectionBackground">#F8FAFC</Color>

    <!-- TEXT -->
    <Color x:Key="TextPrimary">#1E293B</Color>
    <Color x:Key="TextSecondary">#64748B</Color>
    <Color x:Key="TextMuted">#94A3B8</Color>

    <!-- STATUS COLOURS -->
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Danger">#EF4444</Color>

    <!-- BORDER / LINES -->
    <Color x:Key="BorderColor">#E5E7EB</Color>

    <!-- BUTTONS -->
    <Color x:Key="ButtonPrimary">#6366F1</Color>
    <Color x:Key="ButtonSecondary">#34D399</Color>
    <Color x:Key="ButtonNeutral">#CBD5F5</Color>

    <!-- BASIC -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

</ResourceDictionary>