<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CSVGxpInventoryApp.MainPage"
             Title="System Inventory">

    <VerticalStackLayout Padding="20" Spacing="15">

        <Label Text="GxP System Inventory"
               FontSize="26"
               FontAttributes="Bold"
               HorizontalOptions="Center" />

        <CollectionView ItemsSource="{Binding Systems}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeThickness="1"
                            Padding="12"
                            Margin="0,5">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="{Binding SystemName}"
                                   FontSize="18"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Owner}"
                                   FontSize="14" />

                            <Label Text="{Binding Vendor}"
                                   FontSize="14" />

                            <Label Text="{Binding ValidationStatus}"
                                   FontSize="14" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>