<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CSVGxpInventoryApp.Views.AddSystemPage"
             Title="Add System"
             BackgroundColor="{StaticResource AppBackground}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- HEADER -->
            <Border StrokeThickness="0"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="22"
                    StrokeShape="RoundRectangle 22">

                <VerticalStackLayout Spacing="8">
                    <Label Text="Add System Record"
                           Style="{StaticResource PageTitle}" />

                    <Label Text="Enter computerised system details and define the compliance schedule."
                           Style="{StaticResource PageSubtitle}" />
                </VerticalStackLayout>

            </Border>

            <!-- MAIN CARD -->
            <Border StrokeThickness="1"
                    Stroke="{StaticResource BorderColor}"
                    BackgroundColor="{StaticResource CardBackground}"
                    Padding="20"
                    StrokeShape="RoundRectangle 22">

                <VerticalStackLayout Spacing="20">

                    <!-- SYSTEM DETAILS -->
                    <Border StrokeThickness="0"
                            BackgroundColor="{StaticResource SectionBackground}"
                            Padding="18"
                            StrokeShape="RoundRectangle 18">

                        <VerticalStackLayout Spacing="14">

                            <Label Text="System Details"
                                   Style="{StaticResource SectionTitle}" />

                            <Grid ColumnDefinitions="*,*"
                                  RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                  ColumnSpacing="16"
                                  RowSpacing="14">

                                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Spacing="6">
                                    <Label Text="System ID" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Entry Text="{Binding SystemCode}" Placeholder="e.g. LAB-UV-001" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="0" Grid.Column="1" Spacing="6">
                                    <Label Text="System Name" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Entry Text="{Binding SystemName}" Placeholder="e.g. Empower, Polarimeter" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="1" Grid.Column="0" Spacing="6">
                                    <Label Text="Department" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Picker Title="Select department"
                                            ItemsSource="{Binding Departments}"
                                            SelectedItem="{Binding SelectedDepartment}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="1" Grid.Column="1" Spacing="6">
                                    <Label Text="System Owner" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Entry Text="{Binding Owner}" Placeholder="e.g. QC Manager" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="2" Grid.Column="0" Spacing="6">
                                    <Label Text="Vendor" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Entry Text="{Binding Vendor}" Placeholder="e.g. Waters, Shimadzu" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="2" Grid.Column="1" Spacing="6">
                                    <Label Text="Software Version" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Entry Text="{Binding SoftwareVersion}" Placeholder="e.g. v1.0" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="3" Grid.Column="0" Spacing="6">
                                    <Label Text="GAMP 5 Category" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Picker Title="Select GAMP 5 category"
                                            ItemsSource="{Binding GampCategories}"
                                            SelectedItem="{Binding SelectedGampCategory}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="3" Grid.Column="1" Spacing="6">
                                    <Label Text="GxP Relevant?" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Picker Title="Select Yes or No"
                                            ItemsSource="{Binding GxpOptions}"
                                            SelectedItem="{Binding SelectedGxpOption}" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Grid.Row="4" Grid.ColumnSpan="2" Spacing="6">
                                    <Label Text="Validation Status" FontAttributes="Bold" TextColor="{StaticResource TextSecondary}" />
                                    <Picker Title="Select validation status"
                                            ItemsSource="{Binding ValidationStatuses}"
                                            SelectedItem="{Binding ValidationStatus}" />
                                </VerticalStackLayout>

                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <!-- COMPLIANCE SCHEDULE -->
                    <Border StrokeThickness="0"
                            BackgroundColor="#EEF2FF"
                            Padding="18"
                            StrokeShape="RoundRectangle 18">

                        <VerticalStackLayout Spacing="16">

                            <Label Text="Compliance Schedule"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#3730A3" />

                            <Grid ColumnDefinitions="*,*,*"
                                  ColumnSpacing="14">

                                <!-- PERIODIC REVIEW -->
                                <Border Grid.Column="0"
                                        StrokeThickness="0"
                                        BackgroundColor="{StaticResource CardBackground}"
                                        Padding="14"
                                        StrokeShape="RoundRectangle 16">

                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="Periodic Review"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />

                                        <Label Text="Last completed date"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextSecondary}" />

                                        <DatePicker Date="{Binding LastReviewDate}" />

                                        <Label Text="Frequency (months)"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextSecondary}" />

                                        <Picker Title="Select frequency"
                                                ItemsSource="{Binding FrequencyOptions}"
                                                SelectedItem="{Binding ReviewFrequencyMonths}" />
                                    </VerticalStackLayout>

                                </Border>

                                <!-- BACKUP VERIFICATION -->
                                <Border Grid.Column="1"
                                        StrokeThickness="0"
                                        BackgroundColor="{StaticResource CardBackground}"
                                        Padding="14"
                                        StrokeShape="RoundRectangle 16">

                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="Backup Verification"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />

                                        <Label Text="Last completed date"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextSecondary}" />

                                        <DatePicker Date="{Binding LastBackupDate}" />

                                        <Label Text="Frequency (months)"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextSecondary}" />

                                        <Picker Title="Select frequency"
                                                ItemsSource="{Binding FrequencyOptions}"
                                                SelectedItem="{Binding BackupFrequencyMonths}" />
                                    </VerticalStackLayout>

                                </Border>

                                <!-- AUDIT TRAIL REVIEW -->
                                <Border Grid.Column="2"
                                        StrokeThickness="0"
                                        BackgroundColor="{StaticResource CardBackground}"
                                        Padding="14"
                                        StrokeShape="RoundRectangle 16">

                                    <VerticalStackLayout Spacing="10">
                                        <Label Text="Audit Trail Review"
                                               FontSize="16"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextPrimary}" />

                                        <Label Text="Last completed date"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextSecondary}" />

                                        <DatePicker Date="{Binding LastAuditTrailReviewDate}" />

                                        <Label Text="Frequency (months)"
                                               FontAttributes="Bold"
                                               TextColor="{StaticResource TextSecondary}" />

                                        <Picker Title="Select frequency"
                                                ItemsSource="{Binding FrequencyOptions}"
                                                SelectedItem="{Binding AuditTrailFrequencyMonths}" />
                                    </VerticalStackLayout>

                                </Border>

                            </Grid>

                        </VerticalStackLayout>
                    </Border>

                    <!-- BUTTONS -->
                    <Grid ColumnDefinitions="*,*"
                          ColumnSpacing="14">

                        <Button Grid.Column="0"
                                Text="Save System"
                                Clicked="OnSaveSystemClicked" />

                        <Button Grid.Column="1"
                                Text="Back to Inventory"
                                Style="{StaticResource NeutralButton}"
                                Clicked="OnBackClicked" />

                    </Grid>

                </VerticalStackLayout>

            </Border>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>